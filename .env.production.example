# Chatwoot Production Environment Variables
# IMPORTANTE: Configure todas as variáveis antes de fazer deploy!

# ========================================
# SEGURANÇA (OBRIGATÓRIO)
# ========================================
# Gere com: openssl rand -hex 64
SECRET_KEY_BASE=MUDE_ISSO_USE_UMA_STRING_LONGA_E_ALEATORIA_DE_NO_MINIMO_64_CARACTERES

# ========================================
# URL DO SEU SITE (OBRIGATÓRIO)
# ========================================
FRONTEND_URL=https://seu-dominio.com.br
# HELPCENTER_URL=https://help.seu-dominio.com.br

# ========================================
# BANCO DE DADOS POSTGRES
# ========================================
POSTGRES_HOST=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=MUDE_ISSO_SENHA_POSTGRES_SEGURA
POSTGRES_DATABASE=chatwoot_production
RAILS_ENV=production

# ========================================
# REDIS (Cache e Background Jobs)
# ========================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=MUDE_ISSO_SENHA_REDIS_SEGURA

# ========================================
# AMBIENTE
# ========================================
NODE_ENV=production
RAILS_MAX_THREADS=5
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
INSTALLATION_ENV=docker

# ========================================
# CONFIGURAÇÃO DE EMAIL (SMTP)
# ========================================
# Use seu provedor de email (Gmail, SendGrid, Mailgun, etc)
MAILER_SENDER_EMAIL=Seu CRM <noreply@seu-dominio.com.br>
SMTP_DOMAIN=seu-dominio.com.br
SMTP_ADDRESS=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USERNAME=seu_email@dominio.com
SMTP_PASSWORD=sua_senha_smtp
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer

# ========================================
# SEGURANÇA E ACESSO
# ========================================
# Desabilitar novos cadastros públicos (recomendado para uso privado)
ENABLE_ACCOUNT_SIGNUP=false
# Forçar SSL/HTTPS
FORCE_SSL=true

# ========================================
# STORAGE (Arquivos e Mídia)
# ========================================
# Para produção, considere usar S3 da AWS ou similar
ACTIVE_STORAGE_SERVICE=local

# ========================================
# WHATSAPP / EVOLUTION API
# ========================================
# Suas configurações do Evolution API virão aqui
# Você pode adicionar via custom attributes por inbox no futuro

# ========================================
# OPCIONAL: Integração com N8N
# ========================================
# Configure webhooks no N8N e use os custom attributes
# para armazenar URLs de webhooks por account

# ========================================
# ACTIVE RECORD ENCRYPTION (Opcional, para 2FA)
# ========================================
# Gere com: docker-compose exec rails bundle exec rails db:encryption:init
# ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
# ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
# ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
